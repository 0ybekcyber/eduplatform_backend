    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-async-errors": "^3.1.1",
    "express-validator": "^6.6.0",
    "ini": "^2.0.0",
    "joi": "^17.6.4",
     "i18n": "^0.15.0",
    "jsonwebtoken": "^8.5.1",
    "moment": "^2.29.1",
    "mysql2": "^2.1.0",
    "mysqldump": "^3.2.0",
